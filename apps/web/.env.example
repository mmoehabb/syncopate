# Auth.js / NextAuth
# Generate a secret with: openssl rand -base64 33
AUTH_SECRET="your-auth-secret-here"

# This forces NextAuth to understand where it is hosted.
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Database Connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/syncopate?schema=public"

# OAuth Providers
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"

AUTH_GITLAB_CLIENT_ID="your-gitlab-client-id"
AUTH_GITLAB_CLIENT_SECRET="your-gitlab-client-secret"

# GitHub App integration
NEXT_PUBLIC_GITHUB_APP_NAME="your-github-app-name"
GITHUB_APP_ID="your-github-app-id"
GITHUB_APP_PRIVATE_KEY="your-github-app-private-key"
GITHUB_WEBHOOK_SECRET="your-github-webhook-secret"
