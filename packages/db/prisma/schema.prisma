// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Authentication Models (Auth.js / NextAuth standard)
// -----------------------------------------------------------------------------

model Account {
  id                String  @id @default(uuid(7))
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid(7))
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(uuid(7))
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now()) // Serves as the join date
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  workspaceMembers WorkspaceMember[]
  boardMembers     BoardMember[]
  assignedTasks    Task[]            @relation("TaskAssignees")
  subscriptions    Subscription[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -----------------------------------------------------------------------------
// App Models
// -----------------------------------------------------------------------------

// -----------------------------------------------------------------------------
// Billing & Subscriptions
// -----------------------------------------------------------------------------

enum PriceInterval {
  WEEK
  MONTH
  YEAR
  LIFETIME
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  EXPIRED
}

model Plan {
  id                    String   @id @default(uuid(7))
  name                  String // e.g., "Hobby", "Standard"
  maxWorkspaces         Int
  maxBoardsPerWorkspace Int
  maxMembersPerBoard    Int
  maxActiveBoards       Int
  isTrial               Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  prices Price[]
}

model Price {
  id            String        @id @default(uuid(7))
  planId        String
  amount        Int // Stored in cents (e.g., 999 = $9.99)
  currency      String        @default("usd")
  interval      PriceInterval
  intervalCount Int           @default(1)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  plan          Plan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
}

model Subscription {
  id                 String             @id @default(uuid(7))
  userId             String
  priceId            String
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  price Price @relation(fields: [priceId], references: [id])

  // A user should realistically only have one active subscription at a time,
  // but we might want to store history, so we don't unique constraint the userId alone.
}

enum Role {
  ADMIN
  MEMBER
}

model Workspace {
  id        String   @id @default(uuid(7))
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members WorkspaceMember[]
  boards  Board[]
}

model WorkspaceMember {
  id          BigInt   @id @default(autoincrement())
  workspaceId String
  userId      String
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Board {
  id             String   @id @default(uuid(7))
  workspaceId    String
  name           String
  repositoryName String? // E.g., "owner/repo" from GitHub
  githubRepoId   String? // The internal GitHub repo ID
  isActive       Boolean  @default(true)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   BoardMember[]
  tasks     Task[]
  labels    Label[]
}

model BoardMember {
  id        BigInt   @id @default(autoincrement())
  boardId   String
  userId    String
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  CHANGES_REQUESTED
  DONE
}

model Task {
  id          BigInt     @id @default(autoincrement())
  boardId     String
  title       String
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  prNumber    Int? // GitHub/GitLab PR number
  branchName  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  board     Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  assignees User[]  @relation("TaskAssignees")
  labels    Label[]
}

model Label {
  id        BigInt   @id @default(autoincrement())
  boardId   String
  name      String
  color     String? // Hex color code
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@unique([boardId, name])
}
