// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Authentication Models (Auth.js / NextAuth standard)
// -----------------------------------------------------------------------------

model Account {
  id                String  @id @default(uuid(7))
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid(7))
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(uuid(7))
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now()) // Serves as the join date
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  workspaceMembers WorkspaceMember[]
  boardMembers     BoardMember[]
  assignedTasks    Task[]             @relation("TaskAssignees")
  reviewingTasks   Task[]             @relation("TaskReviewers")
  subscriptions    Subscription[]
  activityLogs     BoardActivityLog[] @relation("ActorLogs")
  targetedLogs     BoardActivityLog[] @relation("TargetLogs")
  readStates       UserLogReadState[]
  personalAccessTokens PersonalAccessToken[]
}

model PersonalAccessToken {
  id        String   @id @default(uuid(7))
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -----------------------------------------------------------------------------
// App Models
// -----------------------------------------------------------------------------

// -----------------------------------------------------------------------------
// Billing & Subscriptions
// -----------------------------------------------------------------------------

enum PriceInterval {
  WEEK
  MONTH
  YEAR
  LIFETIME
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  EXPIRED
}

model Plan {
  id                    String   @id @default(uuid(7))
  name                  String // e.g., "Hobby", "Standard"
  maxWorkspaces         Int
  maxBoardsPerWorkspace Int
  maxMembersPerBoard    Int
  maxActiveBoards       Int
  isTrial               Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  prices Price[]
}

model Price {
  id            String        @id @default(uuid(7))
  planId        String
  amount        Int // Stored in cents (e.g., 999 = $9.99)
  currency      String        @default("usd")
  interval      PriceInterval
  intervalCount Int           @default(1)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  plan          Plan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
}

model Subscription {
  id                 String             @id @default(uuid(7))
  userId             String
  priceId            String
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  price Price @relation(fields: [priceId], references: [id])

  // A user should realistically only have one active subscription at a time,
  // but we might want to store history, so we don't unique constraint the userId alone.
}

enum Role {
  ADMIN
  MEMBER
}

model Workspace {
  id                   String   @id @default(uuid(7))
  name                 String
  githubInstallationId String?
  isDeleted            Boolean  @default(false)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  members WorkspaceMember[]
  boards  Board[]
}

model WorkspaceMember {
  id          BigInt   @id @default(autoincrement())
  workspaceId String
  userId      String
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Board {
  id             String   @id @default(uuid(7))
  workspaceId    String
  name           String
  repositoryName String? // E.g., "owner/repo" from GitHub
  githubRepoId   String? // The internal GitHub repo ID
  isActive       Boolean  @default(true)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace    Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members      BoardMember[]
  tasks        Task[]
  labels       Label[]
  activityLogs BoardActivityLog[]
}

model BoardMember {
  id            BigInt    @id @default(autoincrement())
  boardId       String
  userId        String
  role          Role      @default(MEMBER)
  voicePeerId   String?
  lastVoicePing DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  CHANGES_REQUESTED
  DONE
  CLOSED
}

model Task {
  id          BigInt     @id @default(autoincrement())
  boardId     String
  title       String
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  prNumber    Int? // GitHub/GitLab PR number
  branchName  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  board                 Board              @relation(fields: [boardId], references: [id], onDelete: Cascade)
  assignees             User[]             @relation("TaskAssignees")
  reviewers             User[]             @relation("TaskReviewers")
  unregisteredAssignees Json               @default("[]")
  unregisteredReviewers Json               @default("[]")
  labels                Label[]
  activityLogs          BoardActivityLog[]
}

model Label {
  id        BigInt   @id @default(autoincrement())
  boardId   String
  name      String
  color     String? // Hex color code
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@unique([boardId, name])
}

enum ActivityType {
  INVITATION
  TASK_UPDATE
  MEMBER_JOIN
  MEMBER_LEAVE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model BoardActivityLog {
  id           String            @id @default(uuid(7))
  boardId      String
  type         ActivityType
  actorId      String?
  targetUserId String?
  taskId       BigInt?
  status       InvitationStatus?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  board      Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  actor      User? @relation("ActorLogs", fields: [actorId], references: [id], onDelete: SetNull)
  targetUser User? @relation("TargetLogs", fields: [targetUserId], references: [id], onDelete: SetNull)
  task       Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

model UserLogReadState {
  id       String   @id @default(uuid(7))
  userId   String   @unique
  lastRead DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// Bug Reports
// -----------------------------------------------------------------------------

model BugReport {
  id        String   @id @default(uuid(7))
  userId    String?
  message   String?  @db.Text
  digest    String?
  stack     String?  @db.Text
  browser   String?
  url       String?
  createdAt DateTime @default(now())
}
