{
  "name": "syncopate-monorepo",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter \"*\" dev",
    "start": "bun run --filter \"*\" start",
    "build": "bun run --filter \"*\" generate && bun run --filter \"*\" build",
    "lint": "bun run --filter \"*\" lint",
    "format": "bun prettier --write .",
    "check": "bun prettier --check .",
    "db:push": "bun run --filter @syncopate/db push",
    "db:generate": "bun run --filter @syncopate/db generate",
    "db:migrate:dev": "bun run --filter @syncopate/db migrate:dev",
    "db:migrate:deploy": "bun run --filter @syncopate/db migrate:deploy",
    "db:migrate:reset": "bun run --filter @syncopate/db migrate:reset",
    "db:seed": "bun run --filter @syncopate/db seed",
    "test": "export $(cat packages/db/.env.test | xargs) && bun run db:push && bun test"
  },
  "packageManager": "bun@1.3.11",
  "devDependencies": {
    "@types/string-similarity": "^4.0.2",
    "dotenv": "^17.4.1",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@octokit/app": "^16.1.2",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/webhooks-types": "^7.6.1",
    "@types/node": "^20.19.39",
    "date-fns": "^4.1.0",
    "next-auth": "5.0.0-beta.30",
    "octokit": "^5.0.5",
    "string-similarity": "^4.0.4",
    "tsx": "^4.21.0"
  }
}
