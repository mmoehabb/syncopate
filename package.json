{
  "name": "syncopate-monorepo",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r generate && pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "pnpm prettier --write .",
    "check": "pnpm prettier --check .",
    "db:push": "pnpm --filter @syncopate/db push",
    "db:generate": "pnpm --filter @syncopate/db generate",
    "db:migrate:dev": "pnpm --filter @syncopate/db migrate:dev",
    "db:migrate:deploy": "pnpm --filter @syncopate/db migrate:deploy",
    "db:migrate:reset": "pnpm --filter @syncopate/db migrate:reset",
    "db:seed": "pnpm --filter @syncopate/db seed"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "devDependencies": {
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "next-auth": "5.0.0-beta.30",
    "@types/node": "^20.19.39",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0"
  }
}
